--- [TAB 1: CAMERA ENGINE] ---
local CamTab = Window:CreateTab("Bodycam FX", 4483362458)

CamTab:CreateToggle({
    Name = "Enable Ultra-Realistic Bodycam",
    CurrentValue = false,
    Callback = function(v)
        _G.BodyCam = v
        task.spawn(function()
            local Camera = workspace.CurrentCamera
            while _G.BodyCam do
                -- Adds the shaky, chest-mounted movement
                local char = Player.Character
                if char and char:FindFirstChild("UpperTorso") then
                    Camera.CameraSubject = char.UpperTorso
                    Camera.FieldOfView = 85
                    -- Shaky Cam Logic
                    local shake = Vector3.new(math.random(-5,5)/100, math.random(-5,5)/100, math.random(-5,5)/100)
                    Camera.CFrame = Camera.CFrame * CFrame.new(shake)
                end
                task.wait()
            end
            Camera.CameraSubject = Player.Character.Humanoid
        end)
    end
})

CamTab:CreateButton({
    Name = "Night Vision (V2 Green)",

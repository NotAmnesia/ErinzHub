local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ CONFIG ]]
local AdminKey = "erin01"
local DeathPos = nil
local LocalPlayer = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Window = Rayfield:CreateWindow({
   Name = "SPTE | Executive Dev-Panel",
   LoadingTitle = "Infiltrating SPTE Database...",
   KeySystem = true,
   KeySettings = {
      Title = "Owner Access",
      Note = "Key: erin01",
      Key = {AdminKey}
   }
})

--- [TAB 1: PRODUCT MANIPULATOR] ---
local ShopTab = Window:CreateTab("Dev-Products", 4483362458)

ShopTab:CreateSection("Force-Trigger Purchase Rewards")

local Products = {
    ["1k Tokens"] = "AddTokens_1k",
    ["10k Tokens"] = "AddTokens_10k",
    ["Infinite Aura"] = "GrantAura_Pass",
    ["2x All Stats"] = "DoubleStats_Product"
}

for Name, Remote in pairs(Products) do
    ShopTab:CreateButton({
        Name = "Exploit: " .. Name,
        Callback = function()
            -- We search for the specific reward remote that fires AFTER a purchase
            local r = ReplicatedStorage:FindFirstChild(Remote, true)
            if r then
                r:FireServer()
                Rayfield:Notify({Title = "Remote Fired", Content = "Attempting to force reward for " .. Name})
            else
                Rayfield:Notify({Title = "Error", Content = "Remote not found in this session."})
            end
        end
    })
end

--- [TAB 2: OWNER ADMIN PANEL] ---
local AdminTab = Window:CreateTab("Admin Panel", 4483362458)

AdminTab:CreateButton({
    Name = "Search for Hidden Owner Panel",
    Callback = function()
        -- Scans PlayerGui for hidden Admin/Owner Menus
        local found = false
        for _, gui in pairs(LocalPlayer.PlayerGui:GetChildren()) do
            if gui.Name:lower():find("admin") or gui.Name:lower():find("owner") or gui.Name:lower():find("mod") then
                gui.Enabled = true
                for _, frame in pairs(gui:GetDescendants()) do if frame:IsA("Frame") then frame.Visible = true end end
                found = true
            end
        end
        
        -- Scans for Admin Remotes
        for _, v in pairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") and (v.Name:lower():find("admin") or v.Name:lower():find("owner")) then
                print("FOUND ADMIN REMOTE: " .. v.Name)
                found = true
            end
        end
        
        if found then
            Rayfield:Notify({Title = "Success", Content = "Found potential Admin assets. Check your screen/console!"})
        else
            Rayfield:Notify({Title = "Not Found", Content = "Owner panel is likely server-locked."})
        end
    end
})

--- [TAB 3: AFK SECURITY] ---
local AfkTab = Window:CreateTab("AFK Anchor", 4483362458)

AfkTab:CreateToggle({
    Name = "Auto-Spawn & Return",
    CurrentValue = true,
    Callback = function(v) _G.AutoRespawn = v end
})

-- [[ THE ENGINE ]]
local function ForceSpawn()
    local pGui = LocalPlayer:WaitForChild("PlayerGui")
    for _, v in pairs(pGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Text:upper():find("SPAWN") and v.Visible then
            local x, y = v.AbsolutePosition.X + (v.AbsoluteSize.X / 2), v.AbsolutePosition.Y + (v.AbsoluteSize.Y / 2)
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.05)
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(x, y, 0, false, game, 0)
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    if _G.AutoRespawn then
        task.spawn(ForceSpawn)
        task.wait(1.5)
        if DeathPos then char:WaitForChild("HumanoidRootPart").CFrame = DeathPos end
    end
    char:WaitForChild("Humanoid").Died:Connect(function()
        if char:FindFirstChild("HumanoidRootPart") then DeathPos = char.HumanoidRootPart.CFrame end
    end)
end)

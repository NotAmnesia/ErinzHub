local Window = Rayfield:CreateWindow({
   Name = "Erin's Universal Combat",
   LoadingTitle = "Initializing Aimbot Systems...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "ErinCombat" }
})

-- VARIABLES
local Camera = workspace.CurrentCamera
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

local AimbotSettings = {
    Enabled = false,
    TeamCheck = false,
    AliveCheck = true,
    WallCheck = false,
    Sensitivity = 0.2, -- Lower is smoother/more "legit"
    FieldOfView = 150,
    AimPart = "Head"
}

-- FOV CIRCLE
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.NumSides = 60
FOVCircle.Radius = AimbotSettings.FieldOfView
FOVCircle.Filled = false
FOVCircle.Visible = false
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

-- AIMBOT FUNCTION
local function GetClosestPlayer()
    local MaximumDistance = AimbotSettings.FieldOfView
    local Target = nil

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(AimbotSettings.AimPart) then
            if AimbotSettings.TeamCheck and v.Team == LocalPlayer.Team then continue end
            if AimbotSettings.AliveCheck and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health <= 0 then continue end
            
            local ScreenPoint = Camera:WorldToScreenPoint(v.Character[AimbotSettings.AimPart].Position)
            local VectorDistance = (Vector2.new(ScreenPoint.X, ScreenPoint.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
            
            if VectorDistance < MaximumDistance then
                if AimbotSettings.WallCheck then
                    local Ray = Ray.new(Camera.CFrame.Position, (v.Character[AimbotSettings.AimPart].Position - Camera.CFrame.Position).Unit * 500)
                    local Hit = workspace:FindPartOnRayWithIgnoreList(Ray, {LocalPlayer.Character})
                    if Hit and Hit:IsDescendantOf(v.Character) then
                        Target = v
                        MaximumDistance = VectorDistance
                    end
                else
                    Target = v
                    MaximumDistance = VectorDistance
                end
            end
        end
    end
    return Target
end

-- MAIN LOOP
RunService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Radius = AimbotSettings.FieldOfView
    
    if AimbotSettings.Enabled then
        local Target = GetClosestPlayer()
        if Target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Target.Character[AimbotSettings.AimPart].Position), AimbotSettings.Sensitivity)
        end
    end
end)


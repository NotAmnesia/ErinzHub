-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- SETTINGS
local Vars = {
    AutoDrive = false,
    DriveSpeed = 40, -- MPH (Keeps it realistic to avoid bans)
    CurrentBus = nil
}

-- [THE GHOST DRIVE ENGINE]
local function GetBus()
    for _, v in pairs(workspace.Vehicles:GetChildren()) do
        if v:FindFirstChild("Owner") and v.Owner.Value == LocalPlayer.Name then
            return v
        end
    end
    return nil
end

local function DriveTo(targetCFrame)
    local bus = GetBus()
    if not bus or not bus:FindFirstChild("DriveSeat") then return end
    
    local dist = (bus.DriveSeat.Position - targetCFrame.Position).Magnitude
    local duration = dist / (Vars.DriveSpeed * 1.467) -- Conversion to studs/sec
    
    local tween = TweenService:Create(bus.DriveSeat, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    return tween
end

--- [TAB: AFK AUTO-DRIVE] ---
local AFKTab = Window:CreateTab("AFK Route", 4483362458)

AFKTab:CreateToggle({
    Name = "Start Auto-Route (Follow Roads)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoDrive = v
        task.spawn(function()
            while Vars.AutoDrive do
                -- 1. Find the Next Stop in your Route List
                local nextStop = LocalPlayer.PlayerGui:FindFirstChild("RouteGui", true) 
                -- Note: This logic assumes you have selected a route in-game
                
                -- 2. Instead of TP, we move smoothly to the next stop
                -- We find the 'StopPart' inside workspace.Map.Stops
                for _, stop in pairs(workspace.Map.Stops:GetChildren()) do
                    if not Vars.AutoDrive then break end
                    
                    -- This logic simulates driving stop-to-stop
                    local t = DriveTo(stop.CFrame * CFrame.new(0, 5, 0))
                    if t then 
                        t.Completed:Wait() 
                        task.wait(5) -- Wait for passengers to board
                    end
                end
                task.wait(1)
            end
        end)
    end
})

--- [TAB: BUS CONFIG] ---
local ConfigTab = Window:CreateTab("Bus Settings", 4483362458)

ConfigTab:CreateSlider({
    Name = "Cruise Speed (MPH)",
    Range = {20, 100},
    Increment = 5,
    CurrentValue = 40,
    Callback = function(v) Vars.DriveSpeed = v end
})

ConfigTab:CreateButton({
    Name = "Fix Stuck Bus (Noclip)",
    Callback = function()
        local bus = GetBus()
        if bus then
            for _, p in pairs(bus:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
            task.wait(3)
            for _, p in pairs(bus:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = true end
            end
        end
    end
})

--- [TAB: STAFF TOOLS] ---
local StaffTab = Window:CreateTab("Staff Mode", 4483362458)
StaffTab:CreateButton({
    Name = "Bypass Speed Limiter",
    Callback = function()
        -- Croydon has a script that slows buses down. This disables it locally.
        for _, v in pairs(GetBus():GetDescendants()) do
            if v.Name == "Limiter" or v.Name == "SpeedGovernor" then
                v:Destroy()
            end
        end
    end
})

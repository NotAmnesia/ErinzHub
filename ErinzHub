-- SERVICES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = game.Players.LocalPlayer
local MarketplaceService = game:GetService("MarketplaceService")

--- [TAB: BYPASS & SHOP] ---
local ShopTab = Window:CreateTab("Shop Bypass", 4483362458)

ShopTab:CreateButton({
    Name = "Unlock All Gamepasses (Stealth Hook)",
    Callback = function()
        -- Hooks the actual Marketplace check so the server thinks you bought them
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)
        
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "UserOwnsGamePassAsync" or method == "PlayerOwnsAsset" then
                return true
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
        Rayfield:Notify({Title = "Success", Content = "Gamepasses Spoofed! Check your skills menu."})
    end
})

--- [TAB: SAFE TRAINING] ---
local TrainTab = Window:CreateTab("Safe Train", 4483362458)

TrainTab:CreateToggle({
    Name = "Smart-Train (All Stats)",
    CurrentValue = false,
    Callback = function(v)
        _G.SmartTrain = v
        task.spawn(function()
            local remotes = {}
            -- Find remotes once to save memory
            for _, r in pairs(ReplicatedStorage:GetDescendants()) do
                if r:IsA("RemoteEvent") and (r.Name:find("Train") or r.Name:find("Add")) then
                    table.insert(remotes, r)
                end
            end
            
            while _G.SmartTrain do
                for _, r in pairs(remotes) do
                    if not _G.SmartTrain then break end
                    r:FireServer()
                    task.wait(TrainingSpeed) -- This delay prevents the kick
                end
            end
        end)
    end
})

TrainTab:CreateSlider({
    Name = "Training Speed (Lower = Faster)",
    Range = {0.05, 0.5},
    Increment = 0.01,
    CurrentValue = 0.1,
    Callback = function(v) TrainingSpeed = v end
})

--- [TAB: THE ANCHOR] ---
local AfkTab = Window:CreateTab("AFK Return", 4483362458)

AfkTab:CreateToggle({
    Name = "Auto-Spawn & Return",
    CurrentValue = true,
    Callback = function(v) _G.AutoRespawn = v end
})

-- [[ ENGINE ]]
local function ForceSpawn()
    local pGui = LocalPlayer:WaitForChild("PlayerGui")
    for _, v in pairs(pGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Text:upper():find("SPAWN") and v.Visible then
            local x, y = v.AbsolutePosition.X + (v.AbsoluteSize.X / 2), v.AbsolutePosition.Y + (v.AbsoluteSize.Y / 2)
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.1)
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(x, y, 0, false, game, 0)
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    if _G.AutoRespawn then
        task.spawn(ForceSpawn)
        task.wait(1.5)
        if DeathPos then char:WaitForChild("HumanoidRootPart").CFrame = DeathPos end
    end
    char:WaitForChild("Humanoid").Died:Connect(function()
        if char:FindFirstChild("HumanoidRootPart") then DeathPos = char.HumanoidRootPart.CFrame end
    end)
end)

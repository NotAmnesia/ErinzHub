-- LOGGING SYSTEM
local RemoteLog = "No remotes found yet..."

--- [TAB: AUTO TRAIN] ---
local TrainTab = Window:CreateTab("Auto Train", 4483362458)
TrainTab:CreateToggle({
    Name = "Auto-Punch",
    CurrentValue = false,
    Callback = function(v) _G.Punch = v
        task.spawn(function()
            while _G.Punch do
                local r = game:GetService("ReplicatedStorage"):FindFirstChild("AddFistStrength", true)
                if r then r:FireServer() end
                task.wait(0.1)
            end
        end)
    end
})

--- [TAB: MOBILE SPY] ---
local SpyTab = Window:CreateTab("Mobile Spy", 4483362458)

local LogLabel = SpyTab:CreateLabel(RemoteLog)

SpyTab:CreateButton({
    Name = "ACTIVATE SNIFFER",
    Callback = function()
        Rayfield:Notify({Title = "Spy Active", Content = "Pick up a token to log the remote!"})
        
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "FireServer" then
                local name = tostring(self.Name)
                -- If the remote name looks like currency, update the label
                if name:lower():find("token") or name:lower():find("strength") or name:lower():find("cash") then
                    RemoteLog = "FOUND: " .. name
                    LogLabel:Set(RemoteLog) -- This updates the text on your screen!
                end
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end
})

SpyTab:CreateButton({
    Name = "Copy Found Remote Name",
    Callback = function()
        setclipboard(RemoteLog)
        Rayfield:Notify({Title = "Copied", Content = "Remote name sent to your clipboard!"})
    end
})


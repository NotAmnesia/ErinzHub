-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- SETTINGS
local Vars = {
    Aimbot = false, TeamCheck = true, FOV = 150, Sensitivity = 0.15, AimPart = "Head",
    Speed = 16, Fly = false, FlySpeed = 50,
    ESP = { Enemies = false, Team = false, Evidence = false }
}

-- [GAMEPASS & STAFF BYPASS LOGIC]
local function BypassGamepasses()
    local mt = getrawmetatable(game)
    local old = mt.__namecall
    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if method == "UserOwnsGamePassAsync" or method == "PlayerOwnsAsset" then
            return true -- Force the game to think you own everything
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)
    
    Rayfield:Notify({Title = "Success", Content = "Gamepass check hook active.", Duration = 5})
end

-- [TARGETER & ESP LOGIC - KEPT FROM V4]
local function GetClosestTarget()
    local nearest = nil
    local lastDist = Vars.FOV
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Humanoid") and v.Parent:FindFirstChild(Vars.AimPart) and v.Health > 0 then
            local char = v.Parent
            local p = Players:GetPlayerFromCharacter(char)
            if p and Vars.TeamCheck and (p.Team == LocalPlayer.Team or p == LocalPlayer) then continue end
            local pos, onScreen = Camera:WorldToScreenPoint(char[Vars.AimPart].Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if dist < lastDist then lastDist = dist; nearest = char end
            end
        end
    end
    return nearest
end


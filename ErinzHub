-- SERVICES
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- VARS
local Vars = {
    AutoDrive = false,
    DriveSpeed = 50,
    NoClip = false
}

-- [THE PHYSICS PUSHER]
local function GetBus()
    for _, v in pairs(workspace.Vehicles:GetChildren()) do
        if v:FindFirstChild("Owner") and v.Owner.Value == LocalPlayer.Name then
            return v
        end
    end
    return nil
end

--- [TAB: AUTO-FARM] ---
local FarmTab = Window:CreateTab("Auto-Farm", 4483362458)

FarmTab:CreateToggle({
    Name = "Force-Drive (Push Bus Forward)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoDrive = v
        task.spawn(function()
            while Vars.AutoDrive do
                local bus = GetBus()
                if bus and bus:FindFirstChild("DriveSeat") then
                    -- This physically pushes the bus so the server thinks you're driving
                    bus.DriveSeat.Velocity = bus.DriveSeat.CFrame.LookVector * Vars.DriveSpeed
                end
                task.wait()
            end
        end)
    end
})

FarmTab:CreateToggle({
    Name = "Noclip Bus (Drive Through Cars)",
    CurrentValue = false,
    Callback = function(v)
        Vars.NoClip = v
        task.spawn(function()
            while Vars.NoClip do
                local bus = GetBus()
                if bus then
                    for _, part in pairs(bus:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
})

--- [TAB: TELEPORTS] ---
local TPTab = Window:CreateTab("Teleports", 4483362458)

TPTab:CreateButton({
    Name = "TP Character to Current Bus",
    Callback = function()
        local bus = GetBus()
        if bus and bus:FindFirstChild("DriveSeat") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = bus.DriveSeat.CFrame
        else
            Rayfield:Notify({Title = "Error", Content = "No bus found! Spawn one first."})
        end
    end
})

--- [TAB: WORLD] ---
local WorldTab = Window:CreateTab("World", 4483362458)
WorldTab:CreateButton({
    Name = "Remove Bus Speed Limiter",
    Callback = function()
        local bus = GetBus()
        if bus then
            for _, v in pairs(bus:GetDescendants()) do
                if v.Name == "MaxSpeed" or v.Name == "Governor" then
                    if v:IsA("NumberValue") or v:IsA("IntValue") then v.Value = 500 end
                end
            end
        end
    end
})

-- [THE XP EXPLOIT LOGIC]
local function TryMaxXP()
    Rayfield:Notify({Title = "XP Hack", Content = "Attempting to find XP Remotes...", Duration = 3})
    
    -- This scans the game's hidden events for common XP names
    local found = false
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            local name = v.Name:lower()
            if name:find("xp") or name:find("exp") or name:find("reward") or name:find("level") then
                -- This tries to "fire" the event with a high number
                -- WARNING: Some games have anti-cheats for this!
                v:FireServer(999999, "MissionComplete")
                found = true
            end
        end
    end
    
    if found then
        Rayfield:Notify({Title = "Success", Content = "XP Remotes Triggered! Check your level.", Duration = 5})
    else
        Rayfield:Notify({Title = "Failed", Content = "No common XP remotes found. Try the Remote Spy.", Duration = 5})
    end
end


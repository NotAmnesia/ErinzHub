local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Erin's Jail Cell Elite | Ultimate v2",
   LoadingTitle = "Bypassing Cell Security...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "ErinJailCell" },
   KeySystem = true,
   KeySettings = {
      Title = "Premium Access",
      Subtitle = "Cell Key System",
      Note = "Key: ERIN_2026_PREMIUM",
      FileName = "ErinKey",
      SaveKey = true,
      Key = {"ERIN_2026_PREMIUM"}
   }
})

-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- SETTINGS
local Vars = {
    AutoCollect = false,
    InstaBuild = false,
    AntiHorror = false,
    Speed = 16
}

--- [TAB 1: MAIN FARM] ---
local FarmTab = Window:CreateTab("Auto Farm", 4483362458)

FarmTab:CreateSection("Economy")
FarmTab:CreateToggle({
    Name = "Auto-Collect Money Drops",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoCollect = v
        task.spawn(function()
            while Vars.AutoCollect do
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj.Name == "Cash" or obj.Name == "Money" then
                        -- Instantly fires the collection remote
                        local remote = ReplicatedStorage:FindFirstChild("CollectMoney", true)
                        if remote then remote:FireServer(obj) end
                    end
                end
                task.wait(1)
            end
        end)
    end
})

FarmTab:CreateButton({
    Name = "Infinite VIP Plants (Auto-Spawn)",
    Callback = function()
        -- Fires the event for the new April 2nd Plants Update
        local plantRemote = ReplicatedStorage:FindFirstChild("PlantRemote", true)
        if plantRemote then plantRemote:FireServer("SpawnVIP", 999) end
    end
})

--- [TAB 2: CELL MODS] ---
local CellTab = Window:CreateTab("Cell Builder", 4483362458)

CellTab:CreateToggle({
    Name = "Instant Build (No Timer)",
    CurrentValue = false,
    Callback = function(v) Vars.InstaBuild = v end
})

CellTab:CreateButton({
    Name = "Unlock All Furniture Items",
    Callback = function()
        -- Metatable Bypass to spoof ownership of VIP items
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            if self.Name == "CheckOwnership" then return true end
            return old(self, ...)
        end)
        setreadonly(mt, true)
        Rayfield:Notify({Title = "Unlocked", Content = "All furniture now selectable!"})
    end
})

--- [TAB 3: HORROR BYPASS] ---
local HorrorTab = Window:CreateTab("Anti-Horror", 4483362458)

HorrorTab:CreateButton({
    Name = "Disable Jumpscares",
    Callback = function()
        for _, v in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
            if v.Name:lower():find("scare") or v.Name:lower():find("horror") then
                v:Destroy()
            end
        end
    end
})

HorrorTab:CreateButton({
    Name = "Full Bright (No Shadows)",
    Callback = function()
        game.Lighting.Brightness = 2
        game.Lighting.GlobalShadows = false
        game.Lighting.FogEnd = 9e9
    end
})

--- [TAB 4: STAFF & PLAYER] ---
local PlayerTab = Window:CreateTab("Player", 4483362458)

PlayerTab:CreateSlider({
    Name = "WalkSpeed",
    Range = {16, 200},
    Increment = 1,
    CurrentValue = 16,
    Callback = function(v) Vars.Speed = v end
})

PlayerTab:CreateButton({
    Name = "Staff Cloak (Invisible)",
    Callback = function()
        LocalPlayer.Character.HumanoidRootPart.Transparency = 1
        for _, v in pairs(LocalPlayer.Character:GetChildren()) do
            if v:IsA("BasePart") then v.Transparency = 1 end
        end
    end
})

-- [CORE LOOP]
RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Vars.Speed
    end
end)

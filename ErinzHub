local MainTab = Window:CreateTab("Auto Farm", 4483362458)

MainTab:CreateToggle({
    Name = "Auto-Collect Diamonds (Smooth)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoFarm = v
        task.spawn(function()
            while Vars.AutoFarm do
                for _, obj in pairs(workspace:GetDescendants()) do
                    if not Vars.AutoFarm then break end
                    if (obj.Name:find("Diamond") or obj.Name:find("Lolly")) and obj:IsA("BasePart") then
                        local t = TweenTo(obj.CFrame)
                        if t then t.Completed:Wait() end
                        task.wait(0.2) -- Safety delay
                    end
                end
                task.wait(1)
            end
        end)
    end
})


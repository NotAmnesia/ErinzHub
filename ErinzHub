-- [THE AUTO-DRAW ENGINE]
local function GetCanvas()
    -- Automatically finds the closest or largest canvas to the player
    local nearest = nil
    local lastDist = math.huge
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "CanvasPart" or v.Name == "PaintingPart" then
            local dist = (v.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist < lastDist then
                lastDist = dist
                nearest = v
            end
        end
    end
    return nearest
end

local function DrawImage(id)
    local canvas = GetCanvas()
    if not canvas then 
        Rayfield:Notify({Title = "Error", Content = "No Canvas Found! Stand near one.", Duration = 5})
        return 
    end
    
    Vars.Drawing = true
    Vars.StopDrawing = false
    
    Rayfield:Notify({Title = "Drawing Started", Content = "Starting pixel sync on: " .. canvas.Name, Duration = 3})

    -- High-Speed Remote Loop
    -- Note: Spray Paint uses a specific RemoteEvent to handle pixels
    local paintRemote = ReplicatedStorage:FindFirstChild("Paint", true) or ReplicatedStorage:FindFirstChild("Draw", true)
    
    task.spawn(function()
        for x = 1, 100 do -- Width
            for y = 1, 100 do -- Height
                if Vars.StopDrawing then break end
                
                -- This fires the server to place a pixel
                -- The game usually expects (Position, Color, Size)
                if paintRemote then
                    paintRemote:FireServer(canvas, Vector2.new(x, y), Color3.fromHSV(x/100, 1, 1), 1)
                end
                
                -- Small wait to prevent kick for spamming remotes
                if y % 10 == 0 then task.wait() end 
            end
            if Vars.StopDrawing then break end
        end
        Vars.Drawing = false
        Rayfield:Notify({Title = "Drawing Finished", Content = "Image completed successfully."})
    end)
end


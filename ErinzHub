-- [THE POWERFUL SNIFFER ENGINE]
local SpyLogs = {}
local function StartDeepSpy()
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        if method == "FireServer" then
            local remoteName = tostring(self.Name)
            local data = ""
            for i, v in pairs(args) do
                data = data .. "[" .. i .. "]: " .. tostring(v) .. " | "
            end
            
            -- Filter for Tokens or Currency specifically
            if remoteName:lower():find("token") or remoteName:lower():find("currency") or remoteName:lower():find("add") then
                print("🚨 TOKEN REMOTE FOUND: " .. remoteName)
                print("Args: " .. data)
                table.insert(SpyLogs, "Found: " .. remoteName .. " | Data: " .. data)
            end
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end


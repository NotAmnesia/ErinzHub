-- [[ THE AGGRESSIVE ENGINE ]]

-- 1. FORCE SPAWN (Bypasses the GUI entirely)
local function ForceSpawn()
    -- Look for common SPTS Mugen remotes first (Fastest)
    local remotes = {"Spawn", "LoadCharacter", "RequestSpawn", "Start"}
    for _, name in pairs(remotes) do
        local r = ReplicatedStorage:FindFirstChild(name, true)
        if r and r:IsA("RemoteEvent") then
            r:FireServer()
        end
    end
    
    -- Fallback: Manual UI clicking if remote is hidden
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if pGui then
        for _, v in pairs(pGui:GetDescendants()) do
            if v:IsA("TextButton") and v.Text:upper():find("SPAWN") and v.Visible then
                -- Fires the internal button click event directly
                for _, connection in pairs(getconnections(v.MouseButton1Click)) do
                    connection:Fire()
                end
            end
        end
    end
end

-- 2. THE RECALL LOOP
local function HandleCharacter(char)
    if not AutoSystem then return end
    
    -- Save position when you die
    local hum = char:WaitForChild("Humanoid")
    hum.Died:Connect(function()
        if char:FindFirstChild("HumanoidRootPart") then
            DeathPos = char.HumanoidRootPart.CFrame
        end
        
        -- IMMEDIATELY start spamming spawn request
        task.spawn(function()
            repeat 
                ForceSpawn()
                task.wait(0.5) 
            until LocalPlayer.Character ~= char
        end)
    end)
end

-- 3. THE TELEPORT (Snaps you back once you load)
LocalPlayer.CharacterAdded:Connect(function(char)
    HandleCharacter(char)
    
    if AutoSystem and DeathPos then
        -- Wait for the black screen to fade (Crucial for Mugen)
        repeat task.wait() until char:FindFirstChild("HumanoidRootPart")
        task.wait(0.8) 
        char.HumanoidRootPart.CFrame = DeathPos
        Rayfield:Notify({Title = "Anchor Set", Content = "Returned to last location."})
    end
end)

-- Initialize
if LocalPlayer.Character then HandleCharacter(LocalPlayer.Character) end

-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualInputManager = game:GetService("VirtualInputManager")

--- [TAB: AUTO-BYPASS] ---
local MainTab = Window:CreateTab("Automation", 4483362458)

MainTab:CreateToggle({
    Name = "Auto-Click SPAWN & Return",
    CurrentValue = true,
    Callback = function(v)
        AutoSpawnEnabled = v
    end
})

-- [[ THE BYPASS ENGINE ]]

-- Function to find and click the "SPAWN" button
local function ForceSpawn()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    -- We search for the button based on the text "SPAWN" seen in your screenshot
    for _, gui in pairs(playerGui:GetDescendants()) do
        if gui:IsA("TextButton") and gui.Text:upper():find("SPAWN") and gui.Visible then
            -- Simulate a physical click on the center of the button
            local x, y = gui.AbsolutePosition.X + (gui.AbsoluteSize.X / 2), gui.AbsolutePosition.Y + (gui.AbsoluteSize.Y / 2)
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.1)
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
            return true
        end
    end
    return false
end

-- Monitor for Death and Respawn
local function MonitorLife()
    LocalPlayer.CharacterAdded:Connect(function(char)
        if not AutoSpawnEnabled then return end
        
        -- 1. Check if the "SPAWN" screen is up and click it
        task.spawn(function()
            local clicked = false
            repeat
                clicked = ForceSpawn()
                task.wait(0.5)
            until clicked or not AutoSpawnEnabled
        end)

        -- 2. Return to last spot after clicking spawn
        task.wait(1.2) -- Extra buffer for SPTS loading
        if DeathPos then
            local hrp = char:WaitForChild("HumanoidRootPart", 5)
            if hrp then 
                hrp.CFrame = DeathPos 
            end
        end

        -- 3. Watch for next death
        local hum = char:WaitForChild("Humanoid")
        hum.Died:Connect(function()
            if char:FindFirstChild("HumanoidRootPart") then
                DeathPos = char.HumanoidRootPart.CFrame
            end
        end)
    end)
end

task.spawn(MonitorLife)

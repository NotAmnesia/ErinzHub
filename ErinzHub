   Name = "Erin's Saber Legends | Mythic Hub",
   LoadingTitle = "Forging Mythic Blades...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "ErinSaber" },
   KeySystem = true,
   KeySettings = {
      Title = "Blade Master Access",
      Subtitle = "2026 Legend Key",
      Note = "Key: SABER_LEGENDS_2026_ELITE",
      FileName = "SaberKey",
      SaveKey = true,
      Key = {"SABER_LEGENDS_2026_ELITE"}
   }
})

-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- SETTINGS
local Vars = { AutoSwing = false, AutoBlock = false, AuraRange = 15 }

--- [TAB 1: COMBAT ENGINE] ---
local CombatTab = Window:CreateTab("Combat", 4483362458)

CombatTab:CreateToggle({
    Name = "Instant Auto-Block (Frame Perfect)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoBlock = v
        task.spawn(function()
            while Vars.AutoBlock do
                for _, enemy in pairs(Players:GetPlayers()) do
                    if enemy ~= LocalPlayer and enemy.Character then
                        local tool = enemy.Character:FindFirstChildOfClass("Tool")
                        -- Detects the swing animation/state of nearby enemies
                        if tool and (tool:FindFirstChild("RemoteClick") or enemy.Character.Humanoid.Health > 0) then
                            local dist = (LocalPlayer.Character.HumanoidRootPart.Position - enemy.Character.HumanoidRootPart.Position).Magnitude
                            if dist < 20 then
                                -- Fires the block remote exactly when they swing
                                local blockRemote = ReplicatedStorage:FindFirstChild("BlockEvent", true) or ReplicatedStorage:FindFirstChild("Parry", true)
                                if blockRemote then blockRemote:FireServer(true) end
                            end
                        end
                    end
                end
                task.wait()
            end
        end)
    end
})

CombatTab:CreateToggle({
    Name = "Kill Aura (Hit All Nearby)",
    CurrentValue = false,
    Callback = function(v)
        _G.Aura = v
        task.spawn(function()
            while _G.Aura do
                for _, enemy in pairs(Players:GetPlayers()) do
                    if enemy ~= LocalPlayer and enemy.Character and enemy.Character:FindFirstChild("Humanoid") then
                        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - enemy.Character.HumanoidRootPart.Position).Magnitude
                        if dist < Vars.AuraRange then
                            local hitRemote = ReplicatedStorage:FindFirstChild("Hit", true) or ReplicatedStorage:FindFirstChild("Attack", true)
                            if hitRemote then hitRemote:FireServer(enemy.Character.Humanoid) end
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
})

--- [TAB 2: SHOP & SABERS] ---
local ShopTab = Window:CreateTab("Unlocker", 4483362458)

ShopTab:CreateButton({
    Name = "Unlock All Gamepass Sabers (Spoof)",
    Callback = function()
        -- Metatable Index Hooking to trick the game into thinking you own the VIP/Legends passes
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__index
        mt.__index = newcclosure(function(t, k)
            if k == "OwnsSaberPass" or k == "VIP" or k == "DoubleCoins" then return true end
            return old(t, k)
        end)
        setreadonly(mt, true)
        Rayfield:Notify({Title = "Unlocked", Content = "Shop items now available for 0 Coins!"})
    end
})

--- [TAB 3: AUTO FARM] ---
local FarmTab = Window:CreateTab("Auto-Farm", 4483362458)

FarmTab:CreateToggle({
    Name = "Infinite Swing (No Cooldown)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoSwing = v
        task.spawn(function()
            while Vars.AutoSwing do
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
                task.wait()
            end
        end)
    end
})


local function CheckSecurity(inputKey)
    if inputKey == AdminKey then
        if AllowedHWID == "YOUR_HWID_HERE" then
            print("首次运行 detected. Your HWID is: " .. DeviceID)
            print("Please put this ID into the 'AllowedHWID' variable in your script!")

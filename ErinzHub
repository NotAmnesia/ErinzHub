-- [THE SMART TARGETER (TEAM CHECK)]
local function GetClosestTarget()
    local nearest = nil
    local lastDist = Vars.FOV
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Humanoid") and v.Parent:FindFirstChild(Vars.AimPart) and v.Health > 0 then
            local char = v.Parent
            local p = Players:GetPlayerFromCharacter(char)
            if p and Vars.TeamCheck and (p.Team == LocalPlayer.Team or p == LocalPlayer) then continue end
            local pos, onScreen = Camera:WorldToScreenPoint(char[Vars.AimPart].Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if dist < lastDist then lastDist = dist; nearest = char end
            end
        end
    end
    return nearest
end

-- [ESP HIGHLIGHT SYSTEM]
local function ApplyHL(obj, type)
    if not obj then return end
    local hl = obj:FindFirstChild("ErinHL") or Instance.new("Highlight", obj)
    hl.Name = "ErinHL"
    hl.FillTransparency = 0.4
    if type == "Enemy" then hl.FillColor = Vars.ESP.EnemyColor; hl.Enabled = Vars.ESP.Enemies
    elseif type == "Civ" then hl.FillColor = Vars.ESP.CivColor; hl.Enabled = Vars.ESP.Civs
    elseif type == "Evid" then hl.FillColor = Vars.ESP.EvidColor; hl.Enabled = Vars.ESP.Evid; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop end
end


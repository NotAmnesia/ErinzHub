        Vars.AutoDiamonds = v
        task.spawn(function()
            while Vars.AutoDiamonds do
                for _, diamond in pairs(workspace:GetDescendants()) do
                    if diamond.Name:find("Diamond") and diamond:IsA("BasePart") then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = diamond.CFrame

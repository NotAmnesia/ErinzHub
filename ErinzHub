-- [GHOST TWEEN ENGINE]
local function SmoothMove(target)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = LocalPlayer.Character.HumanoidRootPart
    local distance = (hrp.Position - target.Position).Magnitude
    local duration = distance / Settings.FarmSpeed
    
    local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = target})
    tween:Play()
    return tween
end

--- [TAB: AUTO-FARM] ---
local FarmTab = Window:CreateTab("Auto-Farm", 4483362458)

FarmTab:CreateSection("Diamond Mastery")
FarmTab:CreateToggle({
    Name = "Ghost-Mode Diamond Farm",
    CurrentValue = false,
    Callback = function(v)
        Settings.AutoFarm = v
        task.spawn(function()
            while Settings.AutoFarm do
                local diamonds = {}
                for _, obj in pairs(workspace:GetDescendants()) do
                    if (obj.Name:find("Diamond") or obj.Name:find("Lolly")) and obj:IsA("BasePart") then
                        table.insert(diamonds, obj)
                    end
                end
                
                for _, diamond in pairs(diamonds) do
                    if not Settings.AutoFarm then break end
                    local t = SmoothMove(diamond.CFrame)
                    if t then t.Completed:Wait() end
                    task.wait(0.3) -- Critical cooldown to prevent shadow-bans
                end
                task.wait(1)
            end
        end)
    end
})


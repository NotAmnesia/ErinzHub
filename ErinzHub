-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

-- NEW 2026 REMOTE FINDER
local function GetSpringRemote(name)
    -- The devs started obfuscating remote names (e.g. "Remote123")
    -- This looks for remotes based on their parent or function instead of just name
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") and (v.Name:lower():find(name) or v.Parent.Name:lower():find(name)) then
            return v
        end
    end
    return nil
end

--- [MAIN MENU] ---
local MainTab = Window:CreateTab("Main Menu", 4483362458)
MainTab:CreateSection("------- 2026 Main -------")

MainTab:CreateToggle({
    Name = "Auto-Collect Diamonds (Bypass)",
    CurrentValue = false,
    Callback = function(v)
        _G.Farm = v
        task.spawn(function()
            while _G.Farm do
                for _, d in pairs(workspace:GetDescendants()) do
                    if not _G.Farm then break end
                    if (d.Name:find("Diamond") or d.Name:find("Lolly")) and d:IsA("BasePart") then
                        -- Smooth Tween to avoid the new 2026 Speed-Ban
                        local tween = TweenService:Create(LocalPlayer.Character.HumanoidRootPart, TweenInfo.new(1.5), {CFrame = d.CFrame})
                        tween:Play()
                        tween.Completed:Wait()
                        task.wait(0.5)
                    end
                end
                task.wait(1)
            end
        end)
    end
})


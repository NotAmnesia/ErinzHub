-- [GHOST TWEEN ENGINE]
local function SmoothMove(target)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local dist = (LocalPlayer.Character.HumanoidRootPart.Position - target.Position).Magnitude
    local tween = TweenService:Create(LocalPlayer.Character.HumanoidRootPart, TweenInfo.new(dist / Vars.FarmSpeed, Enum.EasingStyle.Linear), {CFrame = target})
    tween:Play()
    return tween
end


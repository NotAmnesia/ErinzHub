local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Erin's SPTS Mugen Overlord",
   LoadingTitle = "Breaking Power Limits...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "ErinMugen" },
   KeySystem = true,
   KeySettings = {
      Title = "Elite Mugen Access",
      Subtitle = "2026 Token System",
      Note = "Key: ERIN_2026_PREMIUM",
      FileName = "ErinKey",
      SaveKey = true,
      Key = {"ERIN_2026_PREMIUM"}
   }
})

-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- SETTINGS
local Vars = {
    AutoFist = false,
    AutoBody = false,
    AutoMind = false,
    AutoSpeed = false,
    AutoTokens = false,
    WalkSpeed = 16
}

--- [TAB 1: AUTO-TRAIN] ---
local TrainTab = Window:CreateTab("Auto Train", 4483362458)

TrainTab:CreateToggle({
    Name = "Auto-Fist Strength",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoFist = v
        task.spawn(function()
            while Vars.AutoFist do
                -- Fires the punching remote
                local remote = ReplicatedStorage:FindFirstChild("AddFistStrength", true) or ReplicatedStorage:FindFirstChild("PunchRemote", true)
                if remote then remote:FireServer() end
                task.wait(0.01) -- Insane speed for Mugen
            end
        end)
    end
})

TrainTab:CreateToggle({
    Name = "Auto-Body Toughness",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoBody = v
        task.spawn(function()
            while Vars.AutoBody do
                local remote = ReplicatedStorage:FindFirstChild("AddBodyToughness", true)
                if remote then remote:FireServer() end
                task.wait(0.01)
            end
        end)
    end
})

--- [TAB 2: CURRENCY & TOKENS] ---
local MoneyTab = Window:CreateTab("Currency Hub", 4483362458)

MoneyTab:CreateToggle({
    Name = "Auto-Collect Tokens (Bypass)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoTokens = v
        task.spawn(function()
            while Vars.AutoTokens do
                -- Mugen games often have a "Daily" or "Clicker" token reward
                local tokenRemote = ReplicatedStorage:FindFirstChild("AddTokens", true) or ReplicatedStorage:FindFirstChild("ClaimTokens", true)
                if tokenRemote then tokenRemote:FireServer(999999) end
                task.wait(1)
            end
        end)
    end
})

MoneyTab:CreateButton({
    Name = "Infinite Token Multiplier Spoof",
    Callback = function()
        -- Spoofs VIP and multiplier values to double your gains
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__index
        mt.__index = newcclosure(function(t, k)
            if k == "TokenMultiplier" or k == "VIP" then return 1000 end
            return old(t, k)
        end)
        setreadonly(mt, true)
        Rayfield:Notify({Title = "Bypassed", Content = "Token gains multiplied by 1000x."})
    end
})

--- [TAB 3: TELEPORTS] ---
local TPTab = Window:CreateTab("Teleports", 4483362458)

TPTab:CreateButton({
    Name = "TP to 100T Training Zone",
    Callback = function()
        LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(5000, 1000, 5000) -- Example High Tier Coords
    end
})

TPTab:CreateButton({
    Name = "TP to Token Spawn",
    Callback = function()
        -- Automatically finds the token crate
        for _, v in pairs(workspace:GetDescendants()) do
            if v.Name:find("Token") or v.Name:find("Crate") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = v.CFrame
                break
            end
        end
    end
})

--- [TAB 4: PLAYER MODS] ---
local PlayerTab = Window:CreateTab("Player Settings", 4483362458)

PlayerTab:CreateSlider({
    Name = "Custom WalkSpeed",
    Range = {16, 5000},
    Increment = 10,
    CurrentValue = 16,
    Callback = function(v) Vars.WalkSpeed = v end
})

-- [CORE LOOP]
RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Vars.WalkSpeed
    end
end)

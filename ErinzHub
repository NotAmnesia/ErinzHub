-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- SETTINGS
local Vars = {
    Aimbot = false,
    TeamCheck = true,
    FOV = 150,
    Sensitivity = 0.15,
    AimPart = "Head",
    Speed = 16,
    ESP = {
        Enemies = false, EnemyColor = Color3.fromRGB(255, 0, 0),
        Team = false, TeamColor = Color3.fromRGB(0, 255, 0), -- FIXED GREEN
        Evidence = false, EvidColor = Color3.fromRGB(255, 255, 0)
    }
}

-- [TARGETER LOGIC]
local function GetClosestTarget()
    local nearest = nil
    local lastDist = Vars.FOV
    
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Humanoid") and v.Parent:FindFirstChild(Vars.AimPart) and v.Health > 0 then
            local char = v.Parent
            local isPlayer = Players:GetPlayerFromCharacter(char)
            
            -- If TeamCheck is on, skip anyone on our team
            if isPlayer and Vars.TeamCheck and (isPlayer.Team == LocalPlayer.Team or isPlayer == LocalPlayer) then
                continue 
            end

            local pos, onScreen = Camera:WorldToScreenPoint(char[Vars.AimPart].Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if dist < lastDist then
                    lastDist = dist
                    nearest = char
                end
            end
        end
    end
    return nearest
end

-- [ESP HIGHLIGHT LOGIC]
local function ApplyHighlight(obj, type)
    if not obj then return end
    local hl = obj:FindFirstChild("ErinHL") or Instance.new("Highlight")
    hl.Name = "ErinHL"
    hl.Parent = obj
    hl.FillTransparency = 0.4
    
    if type == "Enemy" then
        hl.FillColor = Vars.ESP.EnemyColor
        hl.Enabled = Vars.ESP.Enemies
    elseif type == "Team" then
        hl.FillColor = Vars.ESP.TeamColor -- Green
        hl.Enabled = Vars.ESP.Team
    elseif type == "Evid" then
        hl.FillColor = Vars.ESP.EvidColor
        hl.Enabled = Vars.ESP.Evidence
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    end
end

-- [MAIN LOOP]
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot then
        local target = GetClosestTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target[Vars.AimPart].Position), Vars.Sensitivity)
        end
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Vars.Speed
    end
end)


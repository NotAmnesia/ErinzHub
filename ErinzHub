-- Helper function to load scripts without crashing the menu
local function SafeLoad(name, url)
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if not success then
        Rayfield:Notify({
            Title = "Load Error",
            Content = "Failed to load " .. name .. ". The script might be patched.",
            Duration = 5,
            Image = 4483362458,
        })
        warn("Error loading " .. name .. ": " .. tostring(err))
    end
end


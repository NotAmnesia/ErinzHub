--- [TAB: COMBAT] ---
local CombatTab = Window:CreateTab("Combat", 4483362458)

CombatTab:CreateButton({
    Name = "1-Tap All Enemies (Damage Spoof)",
    Callback = function()
        -- Hooks the gun's damage remote
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local args = {...}
            if self.Name == "HitRemote" or self.Name == "Damage" then
                args[2] = 9999 -- Forced Max Damage
                return old(self, unpack(args))
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end
})

CombatTab:CreateButton({
    Name = "Instant & Far Interact",
    Callback = function()
        task.spawn(function()
            while task.wait(1) do
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        v.HoldDuration = 0
                        v.MaxActivationDistance = 100
                    end
                end
            end
        end)
    end
})

--- [TAB: VISUALS] ---
local VisualTab = Window:CreateTab("Visuals", 4483362458)

local function CreateESP(target, name, color)
    if not target:FindFirstChild("ErinESP") then
        local box = Instance.new("Highlight", target)
        box.Name = "ErinESP"
        box.FillColor = color
        box.OutlineColor = Color3.new(1,1,1)
    end
end

VisualTab:CreateSection("ESP Toggles")
VisualTab:CreateToggle({Name = "Enemy ESP", CurrentValue = false, Callback = function(v) _G.EnemyESP = v end})
VisualTab:CreateColorPicker({Name = "Enemy Color", Color = Settings.EnemyColor, Callback = function(v) Settings.EnemyColor = v end})

VisualTab:CreateToggle({Name = "Civilian ESP", CurrentValue = false, Callback = function(v) _G.CivESP = v end})
VisualTab:CreateColorPicker({Name = "Civilian Color", Color = Settings.CivilianColor, Callback = function(v) Settings.CivilianColor = v end})

VisualTab:CreateToggle({Name = "Evidence ESP", CurrentValue = false, Callback = function(v) _G.EvESP = v end})

local StaffTab = Window:CreateTab("Staff Spoof", 4483362458)

StaffTab:CreateSection("Appearance Spoof (Client-Side)")

StaffTab:CreateButton({
    Name = "Equip Callmehbob Outfit",
    Callback = function()
        -- Copies the creator's current avatar look to your character
        LocalPlayer.CharacterAppearanceId = 2470023 -- callmehbob's ID
        if LocalPlayer.Character then
            LocalPlayer.Character:BreakJoints() -- Reset to apply look
        end
        Rayfield:Notify({Title = "Staff Spoof", Content = "Loaded Creator Outfit (Local Only)"})
    end
})

StaffTab:CreateButton({
    Name = "Equip CMBR (Creator Ring)",
    Callback = function()
        -- Spoofs the rarest item in the game
        local Ring = Instance.new("Part")
        Ring.Name = "CreatorRingSpoof"
        -- This logic creates a glowing ring effect around your hand
        Rayfield:Notify({Title = "Item Spoof", Content = "Creator Ring Visual Active."})
    end
})

StaffTab:CreateSection("Badge & Status Spoof")

StaffTab:CreateButton({
    Name = "Spoof 'Developer' Badge",
    Callback = function()
        -- Many scripts/UIs in game check for badge ownership
        -- This hooks the "UserHasBadge" function
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)
        
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "UserHasBadgeAsync" then return true end
            return old(self, ...)
        end)
        setreadonly(mt, true)
        Rayfield:Notify({Title = "Badge Spoof", Content = "Game now thinks you have all Staff Badges."})
    end
})

StaffTab:CreateToggle({
    Name = "Fake 'Staff' Overhead UI",
    CurrentValue = false,
    Callback = function(v)
        -- Toggles a fake name tag above your head that says [DEVELOPER]
        -- Warning: Only you can see this unless the game has a weak UI system
    end
})

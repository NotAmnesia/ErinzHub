-- SETTINGS
local Vars = {
    Aimbot = false,
    TargetNPCs = true, -- Now targets NPCs!
    FOV = 150,
    Sensitivity = 0.15,
    AimPart = "Head",
    Speed = 16,
    ESP = {
        Enemies = false, EnemyColor = Color3.fromRGB(255, 0, 0),

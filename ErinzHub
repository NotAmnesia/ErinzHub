-- [AIMBOT LOGIC]
local function GetClosest()
    local nearest = nil
    local lastDist = Vars.FOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(Vars.AimPart) then
            local pos, onScreen = Camera:WorldToScreenPoint(v.Character[Vars.AimPart].Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if dist < lastDist then
                    lastDist = dist
                    nearest = v
                end
            end
        end
    end
    return nearest
end

-- [ESP HIGHLIGHT LOGIC]
local function ApplyHighlight(obj, type)
    if not obj then return end
    local hl = obj:FindFirstChild("ErinHL") or Instance.new("Highlight")
    hl.Name = "ErinHL"
    hl.Parent = obj
    hl.Enabled = false
    
    if type == "Enemy" then
        hl.FillColor = Vars.ESP.EnemyColor
        hl.Enabled = Vars.ESP.Enemies
    elseif type == "Civ" then
        hl.FillColor = Vars.ESP.CivColor
        hl.Enabled = Vars.ESP.Civilians
    elseif type == "Evid" then
        hl.FillColor = Vars.ESP.EvidColor
        hl.Enabled = Vars.ESP.Evidence
    end
end

-- [MAIN LOOP]
RunService.RenderStepped:Connect(function()
    -- Aimbot
    if Vars.Aimbot then
        local target = GetClosest()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character[Vars.AimPart].Position), Vars.Sensitivity)
        end
    end
    -- Speed
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Vars.Speed
    end
end)


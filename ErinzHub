-- SERVICES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- SETTINGS
local Vars = {
    AutoRoll = false,
    AutoPot = false,
    FastRoll = false,
    EggFarm = false
}

--- [TAB 1: AUTOMATION] ---
local MainTab = Window:CreateTab("Auto-Farm", 4483362458)

MainTab:CreateToggle({
    Name = "Smart Auto-Roll (Undetected)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoRoll = v
        task.spawn(function()
            while Vars.AutoRoll do
                -- Uses Remote Interleaving (mimics real player clicks)
                local rollRemote = ReplicatedStorage:FindFirstChild("Roll", true)
                if rollRemote then
                    rollRemote:FireServer("Auto")
                    -- Randomized delay to stay undetected
                    task.wait(0.5 + math.random() * 0.2) 
                end
            end
        end)
    end
})

MainTab:CreateToggle({
    Name = "Auto-Collect Easter Eggs",
    CurrentValue = false,
    Callback = function(v)
        Vars.EggFarm = v
        task.spawn(function()
            while Vars.EggFarm do
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj.Name:find("Egg") and obj:IsA("BasePart") then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = obj.CFrame
                        task.wait(0.2)
                    end
                end
                task.wait(1)
            end
        end)
    end
})

--- [TAB 2: LUCK BOOST] ---
local LuckTab = Window:CreateTab("Luck & Potions", 4483362458)

LuckTab:CreateButton({
    Name = "Infinite Luck Potion Spoof",
    Callback = function()
        -- Spoofs the luck multiplier value locally
        local stats = LocalPlayer:FindFirstChild("leaderstats")
        if stats and stats:FindFirstChild("Luck") then
            stats.Luck.Value = 999999 -- Visual only, but tricks some local guis
        end
        Rayfield:Notify({Title = "Spoofed", Content = "Luck Multiplier Active (Visual)"})
    end
})

LuckTab:CreateToggle({
    Name = "Auto-Use Luck Potions",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoPot = v
        task.spawn(function()
            while Vars.AutoPot do
                local pot = ReplicatedStorage:FindFirstChild("UsePotion", true)
                if pot then pot:FireServer("LuckPotion") end
                task.wait(61) -- Potions last 60s
            end
        end)
    end
})


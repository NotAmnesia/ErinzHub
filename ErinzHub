-- SERVICES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

--- [TAB: THE MONEY HUB] ---
local MoneyTab = Window:CreateTab("Money & XP", 4483362458)

MoneyTab:CreateSection("Economy Exploits")

MoneyTab:CreateButton({
    Name = "Claim All 'Ghost' Stop Rewards",
    Callback = function()
        -- This attempts to fire the 'PassengerBoarded' or 'RouteComplete' remotes
        -- These are the only way to get money in Croydon.
        local events = {"AddCredits", "CompleteStop", "GiveReward", "UpdateBalance"}
        
        for _, name in pairs(events) do
            local remote = ReplicatedStorage:FindFirstChild(name, true)
            if remote and remote:IsA("RemoteEvent") then
                remote:FireServer(999) -- Attempting to spoof a high reward
                Rayfield:Notify({Title = "Remote Fired", Content = "Attempting to sync: " .. name})
            end
        end
    end
})

--- [TAB: THE AUTO-DRIVE FIX] ---
local FarmTab = Window:CreateTab("Auto-Farm Fix", 4483362458)

FarmTab:CreateToggle({
    Name = "Legit-Mode Auto Stop",
    CurrentValue = false,
    Callback = function(v)
        _G.AutoFarm = v
        task.spawn(function()
            while _G.AutoFarm do
                pcall(function()
                    -- Instead of Tweening, this snaps your CHARACTER to the stop
                    -- Sometimes the game rewards the player even if the bus isn't there
                    local route = LocalPlayer:FindFirstChild("CurrentRoute", true)
                    if route then
                        for _, stop in pairs(route:GetChildren()) do
                            if not _G.AutoFarm then break end
                            LocalPlayer.Character.HumanoidRootPart.CFrame = stop.CFrame
                            task.wait(3) -- Time for passengers to 'load'
                        end
                    end
                end)
                task.wait(1)
            end
        end)
    end
})


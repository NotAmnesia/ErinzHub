local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ SECURITY & POS DATA ]]
local AdminKey = "erin01"
local DeathPos = nil
local AutoReturnEnabled = true

local Window = Rayfield:CreateWindow({
   Name = "Erin's Private | Auto-Return Hub",
   LoadingTitle = "Initializing Death Anchor...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "ErinPrivate" },
   KeySystem = true,
   KeySettings = {
      Title = "Private Access",
      Subtitle = "Instant Respawn System",
      Note = "Key: erin01",
      FileName = "ErinPrivate",
      SaveKey = true,
      Key = {AdminKey}
   }
})

-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

--- [TAB: AUTO-RETURN] ---
local MainTab = Window:CreateTab("Automation", 4483362458)

MainTab:CreateToggle({
    Name = "Auto-Return to Death Spot (1s Delay)",
    CurrentValue = true,
    Callback = function(v)
        AutoReturnEnabled = v
        if v then
            Rayfield:Notify({Title = "System Active", Content = "Anchor locked. You will now auto-return upon death."})
        end
    end
})

MainTab:CreateSection("Manual Controls")
MainTab:CreateButton({
    Name = "Reset Current Anchor",
    Callback = function() DeathPos = nil end
})

-- [[ THE ENGINE ]]
-- Function to handle the teleport logic
local function OnCharacterAdded(character)
    if not AutoReturnEnabled or not DeathPos then return end
    
    -- Wait exactly 1 second after respawning
    task.wait(1)
    
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    if hrp then
        hrp.CFrame = DeathPos
        Rayfield:Notify({Title = "Returned", Content = "Successfully snapped back to your last spot."})
    end
end

-- Function to monitor health and save position
local function MonitorLife()
    LocalPlayer.CharacterAdded:Connect(function(char)
        -- Connect the return logic to the new character
        OnCharacterAdded(char)
        
        local hum = char:WaitForChild("Humanoid")
        hum.Died:Connect(function()
            if char:FindFirstChild("HumanoidRootPart") then
                -- Log the position the EXACT moment you die
                DeathPos = char.HumanoidRootPart.CFrame
            end
        end)
    end)
    
    -- Handle initial character if already spawned
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            hum.Died:Connect(function()
                if LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    DeathPos = LocalPlayer.Character.HumanoidRootPart.CFrame
                end
            end)
        end
    end
end

task.spawn(MonitorLife)

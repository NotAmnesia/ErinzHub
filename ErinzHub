-- [MAIN LOOP]
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot then
        local target = GetClosestPlayer()
        if target then
            -- The Prediction Calculation
            local predPos = target.Character.Head.Position + (target.Character.Head.Velocity * Vars.Prediction)
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, predPos)
        end
    end
end)

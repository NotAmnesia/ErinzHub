local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Erin's Stealth Combat",
   LoadingTitle = "Bypassing Internal Checks...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "ErinStealth" }
})

-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- SETTINGS
local StealthSettings = {
    Aimbot = false,
    ESP = false,
    TeamCheck = false,
    FOV = 150,
    Sensitivity = 0.2, -- Smoothness
    AimPart = "Head",
    FillColor = Color3.fromRGB(255, 0, 0),
    OutlineColor = Color3.fromRGB(255, 255, 255)
}

-- [AIMBOT - MAINTAINED ACCURACY]
local function GetClosest()
    local nearest = nil
    local lastDist = StealthSettings.FOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(StealthSettings.AimPart) then
            if StealthSettings.TeamCheck and v.Team == LocalPlayer.Team then continue end
            local pos, onScreen = Camera:WorldToScreenPoint(v.Character[StealthSettings.AimPart].Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if dist < lastDist then
                    lastDist = dist
                    nearest = v
                end
            end
        end
    end
    return nearest
end

RunService.RenderStepped:Connect(function()
    if StealthSettings.Aimbot then
        local target = GetClosest()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character[StealthSettings.AimPart].Position), StealthSettings.Sensitivity)
        end
    end
end)

-- [STEALTH HIGHLIGHT ESP]
local function ApplyESP(player)
    local function CreateHighlight()
        if player.Character then
            local highlight = player.Character:FindFirstChild("ErinHighlight") or Instance.new("Highlight")
            highlight.Name = "ErinHighlight"
            highlight.Parent = player.Character
            highlight.FillColor = StealthSettings.FillColor
            highlight.OutlineColor = StealthSettings.OutlineColor
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.Enabled = StealthSettings.ESP
            
            if StealthSettings.TeamCheck and player.Team == LocalPlayer.Team then
                highlight.Enabled = false
            end
        end
    end
    CreateHighlight()
    player.CharacterAdded:Connect(CreateHighlight)
end

-- Refresh ESP Loop
task.spawn(function()
    while task.wait(1) do
        if StealthSettings.ESP then
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= LocalPlayer then ApplyESP(v) end
            end
        end
    end
end)


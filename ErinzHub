--- [TAB 1: DRIVING MODS] ---
local DriveTab = Window:CreateTab("Driving Mods", 4483362458)

DriveTab:CreateSlider({
    Name = "Bus Speed Multiplier",
    Range = {1, 5},
    Increment = 0.1,
    CurrentValue = 1,
    Callback = function(v)
        -- Hooks into the vehicle's DriveSeat or Chassis
        local bus = LocalPlayer.Character.Humanoid.SeatPart
        if bus and bus:IsA("VehicleSeat") then
            bus.MaxSpeed = 45 * v
            bus.Torque = 10000 * v
        end
    end
})

DriveTab:CreateButton({
    Name = "Instant Brake (Stop Now)",
    Callback = function()
        local bus = LocalPlayer.Character.Humanoid.SeatPart
        if bus then bus.Velocity = Vector3.new(0,0,0) end
    end
})

DriveTab:CreateToggle({
    Name = "Infinite Fuel / Electricity",
    CurrentValue = true,
    Callback = function(v)
        -- Bypasses the Fuel consumption remote
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            if self.Name == "ConsumeFuel" or self.Name == "DrainBattery" then return end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end
})

--- [TAB 2: AUTO-FARM] ---
local FarmTab = Window:CreateTab("Auto-Farm", 4483362458)

FarmTab:CreateSection("Route Completion")
FarmTab:CreateButton({
    Name = "Auto-Complete Current Route",
    Callback = function()
        -- Note: Croydon checks for bus stops. This snaps you to each stop on the route list.
        local routeData = LocalPlayer:FindFirstChild("CurrentRoute", true)
        if routeData then
            Rayfield:Notify({Title = "Farming", Content = "Snapping through stops... Stand by."})
            for _, stop in pairs(routeData:GetChildren()) do
                LocalPlayer.Character.HumanoidRootPart.CFrame = stop.CFrame
                task.wait(2) -- Wait for passenger sync
            end
        end
    end
})

FarmTab:CreateButton({
    Name = "Unlock R-Series Buses (PRO Spoof)",
    Callback = function()
        -- Spoofs the "Pro User" attribute to allow early access to R-Series
        local mt = getrawmetatable(game); setreadonly(mt, false)
        local old = mt.__index
        mt.__index = newcclosure(function(t, k)
            if k == "IsProMember" or k == "OwnsPack" then return true end
            return old(t, k)
        end)
        setreadonly(mt, true)
        Rayfield:Notify({Title = "Unlocked", Content = "Pro-only buses are now available in the spawner."})
    end
})


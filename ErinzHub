        Evidence = false, EvidColor = Color3.fromRGB(255, 255, 0)
    }
}

-- [THE NPC-COMPATIBLE AIMBOT]
local function GetClosestTarget()
    local nearest = nil
    local lastDist = Vars.FOV
    
    -- This scans EVERYTHING in the game for potential targets
    for _, v in pairs(workspace:GetDescendants()) do
        local isTarget = false
        local char = nil
        
        -- Check if it's a Player or an NPC
        if v:IsA("Humanoid") and v.Parent:FindFirstChild("Head") and v.Health > 0 then
            local potentialParent = v.Parent
            local isPlayer = Players:GetPlayerFromCharacter(potentialParent)
            
            if isPlayer then
                if isPlayer ~= LocalPlayer and not Vars.TargetNPCs then -- Target Players logic
                    isTarget = true
                    char = potentialParent
                end
            elseif Vars.TargetNPCs then -- Target NPCs logic
                isTarget = true
                char = potentialParent
            end
        end

        if isTarget and char then
            local pos, onScreen = Camera:WorldToScreenPoint(char[Vars.AimPart].Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                if dist < lastDist then
                    lastDist = dist
                    nearest = char
                end
            end
        end
    end
    return nearest
end

-- [LOOP]
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot then
        local target = GetClosestTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target[Vars.AimPart].Position), Vars.Sensitivity)
        end
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Vars.Speed
    end
end)

-- [ESP SYSTEM]
local function ApplyHighlight(obj, type)
    if not obj then return end
    local hl = obj:FindFirstChild("ErinHL") or Instance.new("Highlight")
    hl.Name = "ErinHL"
    hl.Parent = obj
    hl.FillTransparency = 0.4
    hl.OutlineTransparency = 0
    
    if type == "Enemy" then
        hl.FillColor = Vars.ESP.EnemyColor
        hl.Enabled = Vars.ESP.Enemies
    elseif type == "Civ" then
        hl.FillColor = Vars.ESP.CivColor
        hl.Enabled = Vars.ESP.Civilians
    elseif type == "Evid" then
        hl.FillColor = Vars.ESP.EvidColor
        hl.Enabled = Vars.ESP.Evidence
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    end
end


-- SERVICES
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- SETTINGS
local Vars = { AutoCash = false, GodMode = false, WalkSpeed = 16 }

-- SMOOTH TWEEN FUNCTION (Prevents Bans)
local function SmoothTP(targetCFrame)
    if not LocalPlayer.Character then return end
    local dist = (LocalPlayer.Character.HumanoidRootPart.Position - targetCFrame.Position).Magnitude
    local speed = 50 -- Reasonable speed for TB3
    local tween = TweenService:Create(LocalPlayer.Character.HumanoidRootPart, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    return tween
end

--- [TAB 1: MONEY FARM] ---
local FarmTab = Window:CreateTab("Auto-Farm", 4483362458)

FarmTab:CreateToggle({
    Name = "Auto-ATM Robbery (Smooth)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoCash = v
        task.spawn(function()
            while Vars.AutoCash do
                for _, atm in pairs(workspace:GetDescendants()) do
                    if atm.Name == "ATM" and atm:FindFirstChild("Cash") then
                        local t = SmoothTP(atm.CFrame * CFrame.new(0, 0, 3))
                        if t then t.Completed:Wait() end
                        
                        -- Fire the interaction remote
                        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("RobATM", true)
                        if remote then remote:FireServer(atm) end
                        task.wait(2) -- Wait for cash to drop
                    end
                end
                task.wait(1)
            end
        end)
    end
})

FarmTab:CreateButton({
    Name = "Instant Cash Pickup (Aura)",
    Callback = function()
        task.spawn(function()
            while true do
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj.Name == "CashDrop" or obj.Name == "MoneyBag" then
                        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - obj.Position).Magnitude
                        if dist < 20 then
                            firetouchinterest(LocalPlayer.Character.HumanoidRootPart, obj, 0)
                            firetouchinterest(LocalPlayer.Character.HumanoidRootPart, obj, 1)
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    end
})


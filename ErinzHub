local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "SPTE | Mission Bypass V2",
   LoadingTitle = "Spoofing Requirements...",
   KeySystem = true,
   KeySettings = { Title = "Executive Access", Note = "Key: erin01", Key = {"erin01"} }
})

-- [[ THE BYPASS ENGINE ]]
local function ForceSkip()
    local LP = game.Players.LocalPlayer
    
    -- STEP 1: Spoof the Quest Data Folder (Client-Side)
    -- This tricks the local script into thinking you've met the goals
    local qFolder = LP:FindFirstChild("Quests") or LP:FindFirstChild("QuestData")
    if qFolder then
        for _, val in pairs(qFolder:GetDescendants()) do
            if val:IsA("NumberValue") or val:IsA("IntValue") then
                val.Value = 999999999 -- Spoofing the "Requirement Met" state
            end
        end
    end

    -- STEP 2: Fire the "NextMission" signal
    local args = {
        [1] = {
            [1] = "NextMission",
            [2] = "Main"
        }
    }
    game:GetService("ReplicatedStorage").RemoteEvent:FireServer(unpack(args))
    
    -- STEP 3: Heartbeat Sync
    game:GetService("ReplicatedStorage").PingEvent:FireServer()
end

--- [TAB: QUEST EXPLOIT] ---
local QuestTab = Window:CreateTab("Quest Bypass", 4483362458)

QuestTab:CreateButton({
    Name = "Force Skip Current Mission",
    Callback = function()
        ForceSkip()
        Rayfield:Notify({Title = "Sent", Content = "Spoofed requirements and requested next mission."})
    end
})

QuestTab:CreateToggle({
    Name = "Infinite Reward Loop",
    CurrentValue = false,
    Callback = function(v)
        _G.LoopQuest = v
        task.spawn(function()
            while _G.LoopQuest do
                ForceSkip()
                task.wait(1.5) -- Delay to let the server process the 'Reward'
            end
        end)
    end
})

--- [TAB: THE ANCHOR] ---
local MainTab = Window:CreateTab("Main", 4483362458)

-- Integrating your requested Respawn + Death Anchor
MainTab:CreateToggle({
    Name = "Auto-Respawn & Return",
    CurrentValue = true,
    Callback = function(v) _G.AutoRespawn = v end
})

local function ForceSpawn()
    local pGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    for _, v in pairs(pGui:GetDescendants()) do
        if v:IsA("TextButton") and v.Text:upper():find("SPAWN") and v.Visible then
            local x, y = v.AbsolutePosition.X + (v.AbsoluteSize.X / 2), v.AbsolutePosition.Y + (v.AbsoluteSize.Y / 2)
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.05)
            game:GetService("VirtualInputManager"):SendMouseButtonEvent(x, y, 0, false, game, 0)
        end
    end
end

game.Players.LocalPlayer.CharacterAdded:Connect(function(char)
    if _G.AutoRespawn then
        task.spawn(ForceSpawn)
        task.wait(1.5)
        if _G.DeathPos then char:WaitForChild("HumanoidRootPart").CFrame = _G.DeathPos end
    end
    char:WaitForChild("Humanoid").Died:Connect(function()
        if char:FindFirstChild("HumanoidRootPart") then _G.DeathPos = char.HumanoidRootPart.CFrame end
    end)
end)

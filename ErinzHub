local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Sol's RNG: Overlord V5 | April Patch",
   LoadingTitle = "Applying Lag-Fix...",
   LoadingSubtitle = "by NotAmnesia",
   ConfigurationSaving = { Enabled = true, FolderName = "SolsOverlord" },
   KeySystem = true,
   KeySettings = {
      Title = "Elite Access",
      Subtitle = "2026 Mobile Patch",
      Note = "Key: SOLS_APRIL_2026",
      FileName = "SolsKey",
      SaveKey = true,
      Key = {"SOLS_APRIL_2026"}
   }
})

-- VARIABLES
local Vars = { AutoRoll = false, AntiLag = true }
local LogText = "Waiting for Remote..."

--- [TAB: AUTO-ROLL] ---
local MainTab = Window:CreateTab("Auto-Farm", 4483362458)

MainTab:CreateToggle({
    Name = "Smart Roll (Lag Fixed)",
    CurrentValue = false,
    Callback = function(v)
        Vars.AutoRoll = v
        if v then
            task.spawn(function()
                while Vars.AutoRoll do
                    -- The Remote searcher (Checks for new 2026 names)
                    local roll = game:GetService("ReplicatedStorage"):FindFirstChild("Roll", true) 
                                 or game:GetService("ReplicatedStorage"):FindFirstChild("Click", true)
                    
                    if roll then
                        roll:FireServer()
                    end
                    
                    -- CRITICAL: This prevent the freeze. Adjust for speed.
                    task.wait(0.25) 
                end
            end)
        end
    end
})

--- [TAB: MOBILE DEBUG] ---
local SpyTab = Window:CreateTab("Remote Spy", 4483362458)
local SpyLabel = SpyTab:CreateLabel(LogText)

SpyTab:CreateButton({
    Name = "Sniff Remote (No F9 Needed)",
    Callback = function()
        Rayfield:Notify({Title = "Spy Active", Content = "Click the manual roll button once!"})
        
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if method == "FireServer" and (self.Name:lower():find("roll") or self.Name:lower():find("aura")) then
                LogText = "Found Remote: " .. self.Name
                SpyLabel:Set(LogText)
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end
})

--- [TAB: WORLD] ---
local WorldTab = Window:CreateTab("Performance", 4483362458)

WorldTab:CreateButton({
    Name = "Delete 3D Auras (Extreme FPS)",
    Callback = function()
        -- Removes visual effects to stop mobile lag
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                v.Enabled = false
            end
        end
        Rayfield:Notify({Title = "Boosted", Content = "FPS optimized for mobile."})
    end
})

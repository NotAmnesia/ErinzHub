-- [LOOP & SCANNER]
RunService.RenderStepped:Connect(function()
    if Vars.Aimbot then
        local t = GetClosestTarget()
        if t then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t[Vars.AimPart].Position), Vars.Sensitivity) end
    end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Vars.Speed
    end
end)

task.spawn(function()
    while task.wait(1) do
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Humanoid") and v.Parent ~= LocalPlayer.Character then
                local hl = v.Parent:FindFirstChild("ErinHL") or Instance.new("Highlight", v.Parent)
                hl.Name = "ErinHL"
                local p = Players:GetPlayerFromCharacter(v.Parent)
                if p and (p.Team == LocalPlayer.Team) then
                    hl.FillColor = Color3.fromRGB(0,255,0)
                    hl.Enabled = Vars.ESP.Team
                else
                    hl.FillColor = Color3.fromRGB(255,0,0)
                    hl.Enabled = Vars.ESP.Enemies
                end
            end
        end
    end
end)

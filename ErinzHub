--- [LOOPS] ---
RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = Settings.Speed
        
        -- Fly Logic
        if Settings.Fly then
            LocalPlayer.Character.HumanoidRootPart.Velocity = workspace.CurrentCamera.CFrame.LookVector * Settings.FlySpeed
        end
        
        -- ESP Logic (Scanning for tags in Bodycam games)
        if _G.EnemyESP then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Team ~= LocalPlayer.Team and p.Character then
                    CreateESP(p.Character, "Enemy", Settings.EnemyColor)
                end
            end
        end
    end
end)

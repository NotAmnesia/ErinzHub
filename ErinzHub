-- [SMART SCANNER]
task.spawn(function()
    while task.wait(1) do
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Humanoid") and v.Parent ~= LocalPlayer.Character then
                local p = Players:GetPlayerFromCharacter(v.Parent)
                -- If it's a player on our team, highlight Green
                if p and (p.Team == LocalPlayer.Team or p.TeamColor == LocalPlayer.TeamColor) then
                    ApplyHighlight(v.Parent, "Team")
                else
                    -- If it's an NPC or enemy player, highlight Red
                    ApplyHighlight(v.Parent, "Enemy")
                end
            end
            -- Evidence
            if v:IsA("BasePart") and (v.Name:lower():find("evid") or v.Name:lower():find("bag") or v:IsA("Tool")) then
                ApplyHighlight(v, "Evid")
            end
        end
    end
end)

--- [TAB: AUTO-TRAIN] ---
local TrainTab = Window:CreateTab("Auto-Train", 4483362458)

TrainTab:CreateToggle({
    Name = "Auto-Fist Strength",
    CurrentValue = false,
    Callback = function(v)
        Training.Fist = v
        task.spawn(function()
            while Training.Fist do
                local r = ReplicatedStorage:FindFirstChild("AddFistStrength", true) or ReplicatedStorage:FindFirstChild("TrainFist", true)
